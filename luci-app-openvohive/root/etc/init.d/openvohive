#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

BIN="/opt/openvohive/openvohive"
CONFIG="/opt/openvohive/config/config.yaml"
RUNTIME_DIR="/opt/openvohive"

start_service() {
	local enabled

	enabled="$(uci -q get openvohive.main.enabled)"
	[ "$enabled" = "1" ] || {
		echo "Open-VoHive is disabled in /etc/config/openvohive"
		return 1
	}

	mkdir -p "$RUNTIME_DIR/data" "$RUNTIME_DIR/logs"

	[ -x "$BIN" ] || {
		echo "Open-VoHive core is not installed: $BIN"
		return 1
	}

	# 加载 qmi_wwan 驱动
	modprobe qmi_wwan 2>/dev/null || true

	procd_open_instance
	procd_set_param command /bin/sh -c "cd '$RUNTIME_DIR' && exec '$BIN' -c '$CONFIG'"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger openvohive
}

reload_service() {
	restart
}
