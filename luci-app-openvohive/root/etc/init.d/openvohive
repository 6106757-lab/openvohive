#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

BIN="/opt/openvohive/openvohive"
CONFIG="/opt/openvohive/config/config.yaml"
RUNTIME_DIR="/opt/openvohive"

# 生成默认 config.yaml（仅在不存在时）
generate_default_config() {
	[ -f "$CONFIG" ] && return 0
	mkdir -p "$(dirname "$CONFIG")"

	cat > "$CONFIG" <<'YAML'
server:
    port: 7575
    debug: false
web:
    username: admin
    password: $2b$10$v50pqRUsRc3zHBY9hILGQ.RBOEy.gU2NGFLZWvL9MgQLy6TJGax6K
devices: []
email:
    enabled: false
    from_address: ""
    password: ""
    smtp_host: ""
    smtp_port: 587
    to_addresses: []
    username: ""
telegram:
    admin_id: 0
    base_url: ""
    bot_token: ""
    chat_id: 0
    enabled: false
    proxy: ""
webhook:
    enabled: false
    headers: {}
    retry_max: 3
    secret: ""
    text_template: "{{device_label}} {{text}}"
    timeout_ms: 5000
    urls: []
YAML

	logger -t openvohive "Generated default config at $CONFIG"
}

start_service() {
	local enabled

	enabled="$(uci -q get openvohive.main.enabled)"
	[ "$enabled" = "1" ] || {
		echo "Open-VoHive is disabled in /etc/config/openvohive"
		return 1
	}

	mkdir -p "$RUNTIME_DIR/data" "$RUNTIME_DIR/logs"

	[ -x "$BIN" ] || {
		echo "Open-VoHive core is not installed: $BIN"
		return 1
	}

	# 生成默认配置（首次安装）
	generate_default_config

	# 加载 qmi_wwan 驱动
	modprobe qmi_wwan 2>/dev/null || true

	procd_open_instance
	procd_set_param command /bin/sh -c "cd '$RUNTIME_DIR' && exec '$BIN' -c '$CONFIG'"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger openvohive
}

reload_service() {
	restart
}
